# === 必要環境變數 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FINNHUB_API_KEY=your_finnhub_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
# 透過 OpenRouter 統一接入 LLM（OpenAI-compatible），預設走 Anthropic Claude
# 以保留 prompt caching 紅利。可改 anthropic/claude-haiku-4.5、openai/gpt-4o 等。
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === 選用設定 ===
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_PLANNER_MODEL=anthropic/claude-haiku-4.5
# 自訂 OpenRouter base url（私有部署或 proxy 用），預設 https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=
# OpenRouter 排行榜歸屬（選填）
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Stock Analysis Telegram Bot
APP_ENV=production              # dev / staging / production
BOT_MODE=polling                # polling / webhook
WEBHOOK_URL=                    # Webhook 模式時必填

# === 健康檢查 ===
HEALTH_ENABLED=true
HEALTH_PORT=8080

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=5

# === 資料庫 ===
DB_PATH=bot_data.db

# === 快取 ===
CACHE_TTL=300                   # 秒

# === 功能開關 ===
PEER_COMPARISON_ENABLED=true
HISTORY_ENABLED=true

# === tenk 10-K / 10-Q 深度分析 ===
# 注意：TENK_* 設定已寫死於 config.py，部署時不需設定這些環境變數
LLAMA_CLOUD_API_KEY=                    # 選用，doc_converter 的 LlamaParse fallback
