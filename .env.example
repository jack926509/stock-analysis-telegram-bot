# === 必要環境變數 ===

# Slack Bot Token（xoxb-…）：到 https://api.slack.com/apps 你的 App > OAuth & Permissions 取得
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token（xapp-…）：Socket Mode 必需
# 你的 App > Basic Information > App-Level Tokens > Generate Token and Scopes
# scope 必須包含 connections:write
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Slack Signing Secret（Socket Mode 不需要；HTTP 模式才需要）
SLACK_SIGNING_SECRET=

# 預設播報頻道（選填）：留空時 bot 只在被 mention / DM / slash command 的當前頻道回覆
# 例如：C01234567 或 #stock-alerts
SLACK_DEFAULT_CHANNEL=

# 數據 API
FINNHUB_API_KEY=your_finnhub_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
# OpenAI 官方 API key（https://platform.openai.com/api-keys）
OPENAI_API_KEY=your_openai_api_key_here

# === 選用設定 ===
# 主分析模型（/report）— 推理深度需求高
OPENAI_MODEL=gpt-4o
# 結構化任務模型（newsletter planner / tenk 中的 footnotes / glossary 等）— 輕推理省錢
OPENAI_PLANNER_MODEL=gpt-4o-mini
# OpenAI base URL（自訂 proxy / Azure OpenAI 才需要設；空字串走預設 https://api.openai.com/v1）
OPENAI_BASE_URL=
# OpenAI 組織與專案 ID（選填）
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

APP_ENV=production              # dev / staging / production

# === 健康檢查 ===
HEALTH_ENABLED=true
HEALTH_PORT=8080

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=5

# === 並發 ===
ANALYSIS_CONCURRENCY=3          # 同時最多幾筆 /report 在跑

# === 資料庫（Postgres）===
# Zeabur Postgres add-on 會自動注入；本地開發請啟動本機 Postgres 然後填這個
# 格式：postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stockbot
# 連線池（選填）：DB_POOL_MAX 預設 15，因背景 newsletter / watchlist / tenk
# 會與前景查詢並發，10 在尖峰可能不夠
DB_POOL_MIN=1
DB_POOL_MAX=15
DB_POOL_TIMEOUT=30

# === 快取 ===
CACHE_TTL=300                   # 秒

# === 功能開關 ===
PEER_COMPARISON_ENABLED=true
HISTORY_ENABLED=true
NEWSLETTER_ENABLED=true

# === tenk 10-K / 10-Q 深度分析 ===
# 大部分 TENK_* 採環境變數，方便調整每日上限或 pipeline 逾時
TENK_ENABLED=true
TENK_DAILY_LIMIT=3                      # 每使用者每日 /tenk 上限
TENK_REPORT_TTL_DAYS=180                # 報告快取天數
TENK_PIPELINE_TIMEOUT=1800              # 單次 pipeline 上限秒數
TENK_CACHE_DIR=data/tenk_cache
TENK_OUTPUT_DIR=data/tenk_output
TENK_SEC_USER_AGENT=stock-analysis-slack-bot your_email@example.com
LLAMA_CLOUD_API_KEY=                    # 選用，doc_converter 的 LlamaParse fallback
