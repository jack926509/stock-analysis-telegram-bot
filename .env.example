# === 必要環境變數 ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
FINNHUB_API_KEY=your_finnhub_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === 選用設定 ===
ANTHROPIC_MODEL=claude-sonnet-4-6
APP_ENV=production              # dev / staging / production
BOT_MODE=polling                # polling / webhook
WEBHOOK_URL=                    # Webhook 模式時必填

# === 健康檢查 ===
HEALTH_ENABLED=true
HEALTH_PORT=8080

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=5

# === 資料庫 ===
DB_PATH=bot_data.db

# === 快取 ===
CACHE_TTL=300                   # 秒

# === 功能開關 ===
PEER_COMPARISON_ENABLED=true
HISTORY_ENABLED=true

# === tenk 10-K / 10-Q 深度分析 ===
TENK_ENABLED=true
TENK_DAILY_LIMIT=3                      # 每用戶每日次數
TENK_REPORT_TTL_DAYS=180                # 半年內同份財報不重跑
TENK_PIPELINE_TIMEOUT=1800              # 單次最長 30 分鐘
TENK_CACHE_DIR=data/tenk_cache          # 財報 HTM / 章節快取目錄
TENK_OUTPUT_DIR=data/tenk_output        # 報告 markdown / context log
TENK_SEC_USER_AGENT=stock-analysis-telegram-bot xieh.gemini@gmail.com
LLAMA_CLOUD_API_KEY=                    # 選用，doc_converter 的 LlamaParse fallback
