# ── Telegram Bot ──\nFOREX_TELEGRAM_BOT_TOKEN=your_bot_token_here\nFOREX_TELEGRAM_CHAT_ID=your_chat_id_here\n\n# ── Anthropic ──\nANTHROPIC_API_KEY=your_anthropic_api_key_here\nFOREX_ANTHROPIC_MODEL=claude-sonnet-4-6\n\n# ── Tavily ──\nTAVILY_API_KEY=your_tavily_api_key_here\n\n# ── Database ──\nFOREX_DB_PATH=forex_trading.db\n\n# ── Portfolio ──\nFOREX_INITIAL_CAPITAL=100000\nFOREX_RISK_PER_TRADE=0.01\nFOREX_MAX_OPEN_POSITIONS=3\n\n# ── Trading ──\nFOREX_SPREAD=0.30\nFOREX_SLIPPAGE_MAX=0.15\nFOREX_MIN_RR_RATIO=2.0\n\n# ── Scheduler ──\nFOREX_SIGNAL_CHECK_INTERVAL=300\nFOREX_POSITION_CHECK_INTERVAL=60\n\n# ── Mode ──\nFOREX_MODE=simulation\nAPP_ENV=production\n